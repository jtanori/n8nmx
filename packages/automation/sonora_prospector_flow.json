      "typeVersion": 2.2,
      "position": [1200, 200],
      "credentials": {
        "postgres": {
          "id": "TU_ID_DE_CREDENCIAL_POSTGRES",
          "name": "Sonora_Engine_DB"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE search_queries SET is_executed = TRUE WHERE id = '{{ $node[\"Get Next Task\"].json[\"task_id\"] }}';"
      },
      "id": "7",
      "name": "Mark Task Completed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.2,
